<?xml version="1.0" encoding="UTF-8"?>
<ConfigParams>
    <Params>
        <config_name>
            <longName>none</longName>
            <type>3</type>
            <transmittable>0</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot;-qt-paragraph-type:empty; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;br /&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine></cDefine>
            <valString>main_config_t</valString>
            <maxLen>0</maxLen>
        </config_name>
        <hw_name>
            <longName>JFBMS Slave</longName>
            <type>0</type>
            <transmittable>0</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;JetFleet BMS Slave Board - Dual BQ76952 cell monitoring module.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine></cDefine>
        </hw_name>
        <slave_id>
            <longName>Slave ID</longName>
            <type>2</type>
            <transmittable>1</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Slave ID on the BMS CAN bus (1-8). Each slave must have a unique ID.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine>CONF_SLAVE_ID</cDefine>
            <editorScale>1</editorScale>
            <editAsPercentage>0</editAsPercentage>
            <maxInt>8</maxInt>
            <minInt>1</minInt>
            <showDisplay>0</showDisplay>
            <stepInt>1</stepInt>
            <valInt>2</valInt>
            <suffix></suffix>
            <vTx>4</vTx>
        </slave_id>
        <can_baud_rate>
            <longName>CAN Baud Rate</longName>
            <type>4</type>
            <transmittable>1</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Sans Serif';&quot;&gt;CAN-bus baud rate. Must match master BMS. Protocol specifies 500 kbps.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine>CONF_CAN_BAUD_RATE</cDefine>
            <valInt>2</valInt>
            <enumNames>CAN_BAUD_125K</enumNames>
            <enumNames>CAN_BAUD_250K</enumNames>
            <enumNames>CAN_BAUD_500K</enumNames>
            <enumNames>CAN_BAUD_1M</enumNames>
            <enumNames>CAN_BAUD_10K</enumNames>
            <enumNames>CAN_BAUD_20K</enumNames>
            <enumNames>CAN_BAUD_50K</enumNames>
            <enumNames>CAN_BAUD_75K</enumNames>
            <enumNames>CAN_BAUD_100K</enumNames>
        </can_baud_rate>
        <cells_ic1>
            <longName>Cells IC1</longName>
            <type>2</type>
            <transmittable>1</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Sans Serif';&quot;&gt;Cells on BQ76952 IC1 (lower stack). Must be at least 3 and at most 16.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine>CONF_CELLS_IC1</cDefine>
            <editorScale>1</editorScale>
            <editAsPercentage>0</editAsPercentage>
            <maxInt>16</maxInt>
            <minInt>3</minInt>
            <showDisplay>0</showDisplay>
            <stepInt>1</stepInt>
            <valInt>16</valInt>
            <suffix></suffix>
            <vTx>1</vTx>
        </cells_ic1>
        <cells_ic2>
            <longName>Cells IC2</longName>
            <type>2</type>
            <transmittable>1</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Sans Serif';&quot;&gt;Cells on BQ76952 IC2 (upper stack). Set to 0 for single-chip mode (16 cells max). Max 16 cells for dual-chip mode (32 cells total).&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine>CONF_CELLS_IC2</cDefine>
            <editorScale>1</editorScale>
            <editAsPercentage>0</editAsPercentage>
            <maxInt>16</maxInt>
            <minInt>0</minInt>
            <showDisplay>0</showDisplay>
            <stepInt>1</stepInt>
            <valInt>0</valInt>
            <suffix></suffix>
            <vTx>1</vTx>
        </cells_ic2>
        <temp_res>
            <longName>NTC Resistance</longName>
            <type>4</type>
            <transmittable>1</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;Resistance value for the external temperature sensors. This is the NTC resistance value at 25C. Please select from the list of supported values.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine>CONF_TEMP_RES</cDefine>
            <valInt>2</valInt>
            <enumNames>4.7k</enumNames>
            <enumNames>5k</enumNames>
            <enumNames>10k</enumNames>
            <enumNames>20k</enumNames>
            <enumNames>22k</enumNames>
            <enumNames>47k</enumNames>
            <enumNames>50k</enumNames>
            <enumNames>100k</enumNames>
            <enumNames>200k</enumNames>
        </temp_res>
        <temp_beta>
            <longName>NTC Beta</longName>
            <type>2</type>
            <transmittable>1</transmittable>
            <description>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Roboto'; ; font-weight:400; font-style:normal;&quot;&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;B-Constant value for the NTC used for the external temperature sensors. It is recommended to use the B25-85 value.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</description>
            <cDefine>CONF_TEMP_BETA</cDefine>
            <editorScale>1</editorScale>
            <editAsPercentage>0</editAsPercentage>
            <maxInt>65535</maxInt>
            <minInt>0</minInt>
            <showDisplay>0</showDisplay>
            <stepInt>1</stepInt>
            <valInt>3435</valInt>
            <suffix></suffix>
            <vTx>3</vTx>
        </temp_beta>
    </Params>
    <SerOrder>
        <ser>slave_id</ser>
        <ser>can_baud_rate</ser>
        <ser>cells_ic1</ser>
        <ser>cells_ic2</ser>
        <ser>temp_res</ser>
        <ser>temp_beta</ser>
    </SerOrder>
    <Grouping>
        <group>
            <groupName>General</groupName>
            <subgroup>
                <subgroupName>CAN</subgroupName>
                <subgroupParams>
                    <param>slave_id</param>
                    <param>can_baud_rate</param>
                </subgroupParams>
            </subgroup>
            <subgroup>
                <subgroupName>Cell Configuration</subgroupName>
                <subgroupParams>
                    <param>cells_ic1</param>
                    <param>cells_ic2</param>
                </subgroupParams>
            </subgroup>
            <subgroup>
                <subgroupName>Temperature Sensors</subgroupName>
                <subgroupParams>
                    <param>temp_res</param>
                    <param>temp_beta</param>
                </subgroupParams>
            </subgroup>
        </group>
    </Grouping>
</ConfigParams>
